translationKey: "contact"
---

<section class="contacto-hero">
  <div class="container">
    <h1 class="contacto-hero__title">We are here to listen</h1>
    <p class="contacto-hero__text">
      Do you have questions about our programs or would you like to visit us? Write to us.
    </p>
  </div>
</section>

<section class="contacto-seccion">
  <div class="container contacto-seccion__wrapper">
    <div class="contacto-datos">
      <h2 class="section-title">Information</h2>
      <p class="contacto-datos__intro">
        Visit our facilities or contact us through these channels:
      </p>

      <div class="contacto-datos__items">
        <div class="dato-item">
          <i class="fa-solid fa-location-dot"></i>
          <div>
            <h3>Location</h3>
            <p>Bolivar Street, next to the Museum, Samaipata, Bolivia</p>
          </div>
        </div>
        <div class="dato-item">
          <i class="fa-solid fa-phone"></i>
          <div>
            <h3>Phone</h3>
            <p>+591 7709 8153</p>
          </div>
        </div>
        <div class="dato-item">
          <i class="fa-solid fa-envelope"></i>
          <div>
            <h3>Email</h3>
            <p>contacto@capi-centro.com</p>
          </div>
        </div>
      </div>
    </div>

    <div class="contacto-form">
      <form class="form-container">
        <div class="form-group">
          <label for="nombre">Full Name</label>
          <input
            type="text"
            id="nombre"
            placeholder="e.g., Jane Doe"
            required
          />
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input
            type="email"
            id="email"
            placeholder="jane@example.com"
            required
          />
        </div>
        <div class="form-group">
          <label for="mensaje">How can we help you?</label>
          <textarea
            id="mensaje"
            rows="5"
            placeholder="Tell us about your inquiry..."
            required
          ></textarea>
        </div>
        <button type="submit" class="btn btn--primary btn--full">
          Send Message
        </button>
      </form>
    </div>
    
    <div class="contacto-mapa-full">
      <div class="contacto-datos__mapa">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d473.835668921709!2d-63.87440099738526!3d-18.178403008514152!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x93f0437d7bd0b295%3A0x575c773942302bf0!2sCAPI!5e0!3m2!1ses-419!2sbo!4v1768999805983!5m2!1ses-419!2sbo"
          style="border: 0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        >
        </iframe>
      </div>
    </div>
  </div>
</section>