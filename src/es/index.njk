        <section class="contacto">
            <div class="container">
                <div class="contacto__wrapper">
                    <div class="contacto__info">
                        <h2 class="contacto__title">¿Tienes dudas?</h2>
                        <p class="contacto__text">Déjanos tus datos y nos pondremos en contacto contigo lo antes posible
                            para asesorarte sobre nuestros programas.</p>
                        <ul class="contacto__list">
                            <li><i class="fa-solid fa-check"></i> Atención personalizada</li>
                            <li><i class="fa-solid fa-check"></i> Visitas guiadas al centro</li>
                            <li><i class="fa-solid fa-check"></i> Información sobre becas</li>
                        </ul>
                    </div>

                    <form 
                        class="form"
                        name="contacto-capi"
                        method="POST"
                        data-netlify="true"
                    >
                    <input type="hidden" name="form-name" value="contacto-capi" />
                        <div class="form__group">
                            <input 
                                type="text"
                                name="nombre" 
                                placeholder="Nombre completo" 
                                class="form__input" 
                                required
                            >
                        </div>
                        <div class="form__group">
                            <input 
                                type="email"
                                name="email"
                                placeholder="Correo electrónico"
                                class="form__input"
                                required
                            >
                        </div>
                        <div class="form__group">
                            <textarea 
                                name="mensaje"
                                placeholder="¿En qué podemos ayudarte?" 
                                class="form__input form__input--textarea"
                                required
                            ></textarea>
                        </div>
                        <button type="submit" class="btn btn--primary form__button">Enviar Mensaje</button>
                    </form>
                </div>
            </div>
        </section>